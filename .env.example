
# AlgoForge Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# ─── Database ────────────────────────────────
DATABASE_URL=postgresql://algoforge:algoforge_dev@localhost:5432/algoforge
POSTGRES_USER=algoforge
POSTGRES_PASSWORD=algoforge_dev
POSTGRES_DB=algoforge

# ─── Redis ───────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Authentication ──────────────────────────
JWT_SECRET=super_secret_jwt_key_that_is_at_least_64_characters_long_for_security
JWT_ACCESS_EXPIRY=15m

# ─── Google OAuth (optional) ─────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ─── App ─────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
